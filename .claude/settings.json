{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./src/**)",
      "Write(./docs/**)",
      "Write(./PROJECT.md)",
      "Write(./DESIGN.md)",
      "Edit(./src/**)",
      "Edit(./docs/**)",
      "Edit(./PROJECT.md)",
      "Edit(./DESIGN.md)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(npx:*)"
    ],
    "deny": [
      "Write(./.claude/**)",
      "Edit(./.claude/**)",
      "Write(./src/components/ui/**)",
      "Edit(./src/components/ui/**)",
      "Bash(sudo:*)",
      "Bash(rm:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/protect-files.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/detect-hardcoded.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/enforce-grayscale.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-a11y-attrs.mjs"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify.mjs"
          }
        ]
      }
    ]
  }
}
